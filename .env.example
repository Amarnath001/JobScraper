APP_ENV=development

# Async SQLAlchemy URL (asyncpg). Docker Compose sets this in the app service.
# For local uvicorn against Postgres on the host:
# DATABASE_URL=postgresql+asyncpg://jobscraper:jobscraper@localhost:5432/jobscraper
DATABASE_URL=postgresql+asyncpg://jobscraper:jobscraper@localhost:5432/jobscraper

# Resend — https://resend.com (required for real email sends)
RESEND_API_KEY=

# Must be a verified sender/domain in Resend
EMAIL_FROM="Job Scraper <onboarding@resend.dev>"
EMAIL_TO=you@example.com

# If true, send a short email when no entry-level jobs were first-seen today
SEND_EMPTY_DIGEST=false

# IANA timezone for digest “today” boundaries and the 6:00 AM schedule
TIMEZONE=America/Los_Angeles

PLAYWRIGHT_HEADLESS=true
SCRAPE_TIMEOUT_SECONDS=90
LOG_LEVEL=INFO

# Set false for local dev if you do not want the APScheduler 6 AM job
ENABLE_SCHEDULER=true

# When true, only ingest jobs in the US or US-compatible remote locations
US_ONLY_MODE=true

# Optional: rolling window for scripts/send_daily_digest.py (e.g. 24).
# Unset to use calendar-day boundaries in TIMEZONE (APScheduler default).
# DIGEST_LOOKBACK_HOURS=24
